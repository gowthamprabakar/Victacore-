# ============================================
# VitaCore .gitignore — Dev Team Standard
# ============================================

# === Xcode ===
DerivedData/
*.xcodeproj/xcuserdata/
*.xcworkspace/xcuserdata/
*.xcodeproj/project.xcworkspace/xcshareddata/IDEWorkspaceChecks.plist
*.pbxuser
*.mode1v3
*.mode2v3
*.perspectivev3
xcuserdata/
*.moved-aside
*.hmap
*.ipa
*.dSYM.zip
*.dSYM

# === Swift Package Manager ===
.build/
Packages/*/.build/
.swiftpm/
Package.resolved

# === macOS ===
.DS_Store
**/.DS_Store
._*

# === Model Weights (downloaded at runtime) ===
*.safetensors
*.mlpackage
*.gguf
*.bin
models/

# === Claude / AI Agent ===
.claude/

# === Specify Caches (regeneratable) ===
.specify/presets/.cache/

# === Secrets & Credentials ===
*.env
*.env.local
*.pem
*.p12
*.key
*.cer
*.mobileprovision

# === IDE ===
.vscode/
.idea/
*.swp
*.swo
*~

# === Build Artifacts ===
build/
*.o
*.a
*.dylib

# === Test Artifacts ===
*.xcresult
coverage/
